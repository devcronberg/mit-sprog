# Eksempel: variabler i mit-sprog

# Erklær en tals-variabel med startværdi
erklær alder som nummer = 16

# Erklær en tekst-variabel
erklær navn som streng = "Alice"

# Erklær en sand/falsk-variabel
erklær erElev som sandFalsk = sand

# Skriv variablernes værdier
skriv navn
skriv alder
skriv erElev

# Vis hvad computeren husker
vis hukommelse

# Opdatér en variabel
sæt alder = 17
skriv alder

# Vis hukommelse igen — se at alder er ændret
vis hukommelse
