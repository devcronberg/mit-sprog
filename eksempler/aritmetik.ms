# Aritmetik med tal
erklær a som nummer = 10
erklær b som nummer = 3

skriv a + b
skriv a - b

# Regnestykke i erklæring
erklær sum som nummer = a + b + 100

skriv sum

# Strengsammenkædning
erklær fornavn som streng = "Alice"
erklær efternavn som streng = "Jensen"
skriv fornavn + " " + efternavn

vis hukommelse
